# Copy to `.env` and fill in. `.env` is gitignored — never commit your real key.
# roast-my-app reads .env (this directory) and ~/.roast-my-app.env automatically.

# --- Free default: Groq (https://console.groq.com/keys, no credit card) -------
GROQ_API_KEY=gsk_your_key_here

# --- Or any OpenAI-compatible provider (uncomment one) ------------------------
# OpenRouter free models:
# ROAST_BASE_URL=https://openrouter.ai/api/v1
# ROAST_API_KEY=sk-or-...
# ROAST_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Local Ollama (no key needed):
# ROAST_BASE_URL=http://localhost:11434/v1
# ROAST_MODEL=llama3.1
